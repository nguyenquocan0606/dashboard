generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Enums
enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

enum Cycle {
  MONTHLY
  YEARLY
}

enum TxType {
  INCOME
  EXPENSE
}

model TaskStack {
  id        Int      @id @default(autoincrement())
  name      String
  order     Int      // For ordering stacks
  color     String?  @default("#64748b")
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?    @db.Text
  dueDate     DateTime?  // NOW OPTIONAL
  priority    Priority   @default(MEDIUM)
  status      Status     @default(TODO)
  tags        String?    // Store as comma-separated string or JSON
  stackId     Int?
  stack       TaskStack? @relation(fields: [stackId], references: [id], onDelete: SetNull)
  order       Int        @default(0) // For ordering within stack
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Reminder {
  id          Int      @id @default(autoincrement())
  title       String
  dateTime    DateTime
  isRecurring Boolean  @default(false)
  isCompleted Boolean  @default(false)
  color       String?  @default("#10b981") // Default green
}

model Subscription {
  id              Int      @id @default(autoincrement())
  name            String
  price           Decimal  @db.Decimal(10, 2)
  billingCycle    Cycle
  nextBillingDate DateTime
  isActive        Boolean  @default(true)
  notes           String?
}

model Account {
  id             Int           @id @default(autoincrement())
  name           String
  initialBalance Decimal       @db.Decimal(15, 2) @default(0)
  color          String?
  description    String?
  isPrimary      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  transactions   Transaction[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Decimal  @db.Decimal(10, 2)
  type        TxType
  category    String
  description String?
  date        DateTime @default(now())
  accountId   Int?
  account     Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
}

model CalendarConnection {
  id            Int             @id @default(autoincrement())
  provider      String          // "google" | "apple"
  email         String
  accessToken   String          @db.Text
  refreshToken  String?         @db.Text
  expiresAt     DateTime
  nylasGrantId  String          @unique
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  events        CalendarEvent[]
}

model CalendarEvent {
  id                Int                  @id @default(autoincrement())
  nylasEventId      String               @unique
  sourceType        String               // "task" | "reminder" | "subscription"
  sourceId          Int
  connectionId      Int
  connection        CalendarConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  lastSyncedAt      DateTime             @updatedAt
  createdAt         DateTime             @default(now())

  @@index([sourceType, sourceId])
  @@index([nylasEventId])
}

model SyncLog {
  id           Int      @id @default(autoincrement())
  action       String   // "create" | "update" | "delete" | "webhook"
  sourceType   String
  sourceId     Int?
  nylasEventId String?
  status       String   // "success" | "failed"
  error        String?  @db.Text
  createdAt    DateTime @default(now())
}
